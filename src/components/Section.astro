---
interface Props {
  label?: string;
  title?: string;
  subtitle?: string;
  centered?: boolean;
  tight?: boolean;
  dark?: boolean;
  id?: string;
}

const { label, title, subtitle, centered = false, tight = false, dark = false, id } = Astro.props;
---

<section
  id={id}
  class={`${tight ? 'py-12 md:py-16' : 'py-20 md:py-28'} ${dark ? 'bg-navy' : ''}`}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    {(label || title || subtitle) && (
      <div class={`mb-12 md:mb-16 ${centered ? 'text-center' : ''}`}>
        {label && (
          <p class={`section-label ${dark ? 'text-gold' : ''}`}>{label}</p>
        )}
        {label && <div class={`${centered ? 'mx-auto' : ''} divider-gold`}></div>}
        {title && (
          <h2 class={`font-serif text-3xl md:text-4xl lg:text-5xl ${dark ? 'text-cream' : 'text-navy'} ${centered ? '' : 'max-w-2xl'}`}>
            {title}
          </h2>
        )}
        {subtitle && (
          <p class={`mt-4 font-sans text-base leading-relaxed max-w-2xl ${dark ? 'text-cream/65' : 'text-navy/65'} ${centered ? 'mx-auto' : ''}`}>
            {subtitle}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
