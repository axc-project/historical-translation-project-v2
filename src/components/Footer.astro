---
const year = new Date().getFullYear();
---

<footer class="bg-navy text-cream/80 mt-24">
  <!-- Top section -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 grid md:grid-cols-4 gap-12">
    <!-- Brand -->
    <div class="md:col-span-2">
      <img src="/assets/brand/htp-logo.png" alt="Historical Translation Project™" class="h-12 mb-4 opacity-90" />
      <p class="text-sm leading-relaxed text-cream/60 max-w-sm font-sans mt-4">
        A research institute dedicated to the scholarly translation of classical botanical medicine and the rigorous synthesis of historical pharmacopoeial traditions with contemporary phytomedicine science.
      </p>
      <div class="mt-6 flex items-center gap-3">
        <div class="w-8 h-px bg-gold/40"></div>
        <span class="text-xs font-sans text-cream/40 tracking-widest uppercase">Formulations by</span>
        <img src="/assets/brand/archevia-logo-black.png" alt="Archevia™" class="h-12 opacity-95" />
      </div>
    </div>

    <!-- Links -->
    <div>
      <h4 class="text-xs tracking-widest uppercase text-gold/70 font-sans mb-5">Navigate</h4>
      <ul class="space-y-3 text-sm font-sans">
        <li><a href="/" class="text-cream/60 hover:text-gold transition-colors">Home</a></li>
        <li><a href="/formulations" class="text-cream/60 hover:text-gold transition-colors">Formulations</a></li>
        <li><a href="/publications" class="text-cream/60 hover:text-gold transition-colors">Publications</a></li>
        <li><a href="/research" class="text-cream/60 hover:text-gold transition-colors">Research</a></li>
        <li><a href="/about" class="text-cream/60 hover:text-gold transition-colors">About</a></li>
        <li><a href="/contact" class="text-cream/60 hover:text-gold transition-colors">Contact</a></li>
      </ul>
    </div>

    <!-- Legal -->
    <div>
      <h4 class="text-xs tracking-widest uppercase text-gold/70 font-sans mb-5">Legal</h4>
      <ul class="space-y-3 text-sm font-sans">
        <li><a href="/disclaimer" class="text-cream/60 hover:text-gold transition-colors">Disclaimer</a></li>
        <li><a href="/disclaimer#privacy" class="text-cream/60 hover:text-gold transition-colors">Privacy</a></li>
        <li><a href="/disclaimer#terms" class="text-cream/60 hover:text-gold transition-colors">Terms of Use</a></li>
        <li><a href="/disclaimer#dshea" class="text-cream/60 hover:text-gold transition-colors">DSHEA Notice</a></li>
      </ul>
    </div>
  </div>

  <!-- DSHEA Banner -->
  <div class="border-t border-cream/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-8">
      <p class="text-xs font-sans text-cream/40 leading-relaxed max-w-4xl">
        <strong class="text-gold/60">Notice:</strong> These statements have not been evaluated by the Food and Drug Administration.
        These products are not intended to diagnose, treat, cure, or prevent any disease.
        All content on this website is for educational and informational purposes only and does not constitute medical advice.
        Consult a qualified healthcare practitioner before beginning any supplementation program.
      </p>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-cream/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs font-sans text-cream/30">
        © {year} Historical Translation Project™. All rights reserved. Archevia™ is a trademark of Historical Translation Project.
      </p>
      <p class="text-xs font-sans text-cream/30 italic font-serif">
        Science in the service of tradition. Tradition in the service of health.
      </p>
    </div>
  </div>
</footer>
