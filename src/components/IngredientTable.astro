---
interface Ingredient {
  name: string;
  form: string;
  amount: string;
}

interface Props {
  ingredients: Ingredient[];
}

const { ingredients } = Astro.props;
---

<div class="overflow-x-auto rounded-sm">
  <table class="table-base">
    <thead>
      <tr>
        <th>Ingredient</th>
        <th>Form / Standardization</th>
        <th>Amount Per Serving</th>
      </tr>
    </thead>
    <tbody>
      {ingredients.map(ing => (
        <tr>
          <td class="font-serif font-medium text-navy">{ing.name}</td>
          <td class="text-navy/60 text-xs italic">{ing.form}</td>
          <td class="font-mono text-sm text-navy font-medium">{ing.amount}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="mt-3 text-xs font-sans text-navy/40 italic">
    † Exact specifications subject to batch testing. Consult current Certificate of Analysis.
  </p>
</div>
