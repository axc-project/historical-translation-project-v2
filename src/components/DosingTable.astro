---
interface DoseRow {
  time: string;
  amount: string;
  note?: string;
}

interface Props {
  rows: DoseRow[];
}

const { rows } = Astro.props;
---

<div class="overflow-x-auto rounded-sm">
  <table class="table-base">
    <thead>
      <tr>
        <th>Time</th>
        <th>Amount</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          <td class="font-serif font-medium text-navy">{row.time}</td>
          <td class="font-mono text-sm text-gold font-medium">{row.amount}</td>
          <td class="text-navy/60 text-xs">{row.note || '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
