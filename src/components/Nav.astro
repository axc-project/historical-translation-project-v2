---
const navLinks = [
  { href: '/formulations', label: 'Formulations' },
  { href: '/publications', label: 'Publications' },
  { href: '/research', label: 'Research' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-gold/20 transition-shadow duration-300" id="site-nav">
  <nav class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 hover:opacity-90 transition-opacity">
      <img src="/assets/brand/htp-logo.png" alt="Historical Translation Project™" class="h-14 md:h-16 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-xs font-sans font-medium tracking-widest uppercase transition-colors duration-200
              ${currentPath.startsWith(link.href)
                ? 'text-gold border-b border-gold pb-0.5'
                : 'text-navy/70 hover:text-gold'}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a href="/formulations" class="hidden md:inline-flex btn-primary text-xs py-2 px-5">
      Explore System
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" aria-label="Open menu" class="md:hidden p-2 text-navy">
      <svg width="22" height="16" viewBox="0 0 22 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="8" x2="22" y2="8" stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-gold/20 px-6 py-6">
    <ul class="space-y-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-sm font-sans text-navy/80 hover:text-gold tracking-wider transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/formulations" class="btn-primary w-full justify-center text-xs py-3">
          Explore System
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('shadow-md');
    } else {
      nav?.classList.remove('shadow-md');
    }
  });
</script>
