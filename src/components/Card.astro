---
interface Props {
  title: string;
  description?: string;
  href?: string;
  illustration?: string;
  illustrationAlt?: string;
  badge?: string;
  badgeColor?: 'navy' | 'gold';
  tag?: string;
}

const { title, description, href, illustration, illustrationAlt, badge, badgeColor = 'navy', tag } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class={`card-base group relative flex flex-col ${href ? 'cursor-pointer' : ''}`}
>
  {badge && (
    <div class={`absolute top-6 right-6 text-xs tracking-wider font-sans px-3 py-1 uppercase
      ${badgeColor === 'gold' ? 'bg-gold/10 text-gold border border-gold/30' : 'bg-navy/10 text-navy border border-navy/20'}`}>
      {badge}
    </div>
  )}

  {illustration && (
    <div class="mb-6 w-24 h-24">
      <img src={illustration} alt={illustrationAlt || title} class="w-full h-full object-contain" />
    </div>
  )}

  {tag && (
    <span class="text-xs tracking-widest font-sans uppercase text-gold/70 mb-2">{tag}</span>
  )}

  <h3 class="font-serif text-xl md:text-2xl text-navy mb-3 group-hover:text-gold transition-colors duration-200">
    {title}
  </h3>

  {description && (
    <p class="font-sans text-sm text-navy/65 leading-relaxed flex-1">
      {description}
    </p>
  )}

  {href && (
    <div class="mt-6 flex items-center gap-2 text-xs font-sans font-500 text-gold tracking-wider uppercase group-hover:gap-3 transition-all duration-200">
      <span>Learn more</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 3m5 4L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
  )}

  <slot />
</Tag>
