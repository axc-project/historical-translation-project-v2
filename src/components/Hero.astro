---
interface Props {
  label?: string;
  headline: string;
  subheadline?: string;
  cta?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  dark?: boolean;
}

const { label, headline, subheadline, cta, ctaSecondary, dark = false } = Astro.props;
---

<section class={`relative overflow-hidden py-24 md:py-36 ${dark ? 'bg-navy' : 'bg-cream-warm'}`}>
  <!-- Background pattern -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="absolute right-0 top-0 w-1/2 h-full opacity-5" viewBox="0 0 400 400" fill="none">
      <circle cx="350" cy="100" r="200" stroke={dark ? '#b8860b' : '#0f1e3c'} stroke-width="1"/>
      <circle cx="350" cy="100" r="150" stroke={dark ? '#b8860b' : '#0f1e3c'} stroke-width="0.5"/>
      <circle cx="350" cy="100" r="100" stroke={dark ? '#b8860b' : '#0f1e3c'} stroke-width="0.5"/>
      <!-- Botanical lines -->
      <path d="M200 0 Q250 100 200 200 Q150 300 200 400" stroke={dark ? '#b8860b' : '#0f1e3c'} stroke-width="0.5"/>
      <path d="M220 0 Q270 100 220 200" stroke={dark ? '#b8860b' : '#0f1e3c'} stroke-width="0.5" opacity="0.5"/>
    </svg>
    <svg class="absolute left-0 bottom-0 w-1/3 h-2/3 opacity-5" viewBox="0 0 300 300" fill="none">
      <path d="M0 300 Q50 200 0 100 Q50 50 100 100 Q50 200 100 300Z" fill={dark ? '#b8860b' : '#0f1e3c'}/>
    </svg>
  </div>

  <div class="relative max-w-5xl mx-auto px-6 lg:px-12">
    {label && (
      <div class="flex items-center gap-3 mb-8 fade-in" style="animation-delay:0.1s; opacity:0">
        <div class={`w-8 h-px ${dark ? 'bg-gold' : 'bg-gold'}`}></div>
        <span class={`text-xs tracking-widest uppercase font-sans font-500 ${dark ? 'text-gold' : 'text-gold'}`}>{label}</span>
      </div>
    )}

    <h1 class={`font-serif text-4xl md:text-6xl lg:text-7xl leading-tight mb-8 slide-up ${dark ? 'text-cream' : 'text-navy'}`}
        style="animation-delay:0.2s; opacity:0">
      {headline}
    </h1>

    {subheadline && (
      <p class={`font-sans text-base md:text-lg leading-relaxed max-w-2xl mb-12 slide-up ${dark ? 'text-cream/70' : 'text-navy/65'}`}
         style="animation-delay:0.35s; opacity:0">
        {subheadline}
      </p>
    )}

    {(cta || ctaSecondary) && (
      <div class="flex flex-wrap gap-4 slide-up" style="animation-delay:0.5s; opacity:0">
        {cta && (
          <a href={cta.href} class={dark ? 'btn-gold' : 'btn-primary'}>
            {cta.text}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class={dark ? 'btn-outline border-cream/40 text-cream hover:bg-cream hover:text-navy' : 'btn-outline'}>
            {ctaSecondary.text}
          </a>
        )}
      </div>
    )}
  </div>
</section>
