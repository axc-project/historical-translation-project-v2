---
interface Props {
  label?: string;
  headline: string;
  subheadline?: string;
  cta?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  compact?: boolean;
  useHeroImage?: boolean;
}

const { label, headline, subheadline, cta, ctaSecondary, compact = false, useHeroImage = false } = Astro.props;
const lines = headline.split('\\n');
---

<section class={`relative overflow-hidden ${compact ? 'py-16 md:py-20' : 'py-28 md:py-40'} ${useHeroImage ? '' : 'bg-navy'}`}>

  {useHeroImage ? (
    <!-- Real hero background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/hero-bg.png"
        alt=""
        class="w-full h-full object-cover object-center"
        aria-hidden="true"
      />
      <!-- Overlay: dark left panel so text is legible, lighter right -->
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,20,45,0.88) 0%, rgba(10,20,45,0.75) 45%, rgba(10,20,45,0.30) 100%);"></div>
      <!-- Subtle gold bottom glow -->
      <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, rgba(184,134,11,0.12), transparent);"></div>
    </div>
  ) : (
    <!-- CSS pattern background for inner pages -->
    <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 110%, rgba(184,134,11,0.18) 0%, transparent 70%);"></div>
      <div class="absolute inset-0 opacity-[0.04]" style="
        background-image: repeating-linear-gradient(0deg, transparent, transparent 34px, rgba(184,134,11,0.6) 35px),
                          repeating-linear-gradient(90deg, transparent, transparent 54px, rgba(184,134,11,0.3) 55px);
      "></div>
      <svg class="absolute -top-20 -right-20 w-[500px] h-[500px] opacity-[0.06]" viewBox="0 0 500 500" fill="none">
        <circle cx="250" cy="250" r="240" stroke="#b8860b" stroke-width="1"/>
        <circle cx="250" cy="250" r="180" stroke="#b8860b" stroke-width="0.5"/>
        <circle cx="250" cy="250" r="120" stroke="#b8860b" stroke-width="0.5"/>
        <line x1="250" y1="10" x2="250" y2="490" stroke="#b8860b" stroke-width="0.3"/>
        <line x1="10" y1="250" x2="490" y2="250" stroke="#b8860b" stroke-width="0.3"/>
      </svg>
    </div>
  )}

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-12">
    {label && (
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-px bg-gold/60"></div>
        <span class="text-gold text-xs tracking-widest font-sans font-medium uppercase">{label}</span>
      </div>
    )}

    <h1 class={`font-serif text-cream leading-tight mb-6 ${compact ? 'text-3xl md:text-4xl' : 'text-4xl md:text-6xl lg:text-7xl'}`}>
      {lines.map((line, i) => (
        <span class="block slide-up" style={`animation-delay: ${0.1 + i * 0.15}s; opacity: 0;`}>
          {i === lines.length - 1 && lines.length > 1
            ? <span class="text-gold">{line}</span>
            : line}
        </span>
      ))}
    </h1>

    {subheadline && (
      <p class="font-sans text-cream/75 leading-relaxed max-w-2xl mb-10 slide-up text-base md:text-lg"
         style="animation-delay: 0.4s; opacity: 0;">
        {subheadline}
      </p>
    )}

    {(cta || ctaSecondary) && (
      <div class="flex flex-wrap gap-4 slide-up" style="animation-delay: 0.55s; opacity: 0;">
        {cta && <a href={cta.href} class="btn-primary">{cta.text}</a>}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="inline-flex items-center gap-2 text-sm font-sans text-cream/70 hover:text-gold transition-colors border-b border-cream/20 hover:border-gold pb-0.5">
            {ctaSecondary.text}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12m0 0L8 2m5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        )}
      </div>
    )}
  </div>
</section>
