---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex={true}>
  <div class="min-h-[70vh] flex items-center justify-center bg-cream-warm">
    <div class="text-center px-6 max-w-lg">
      <div class="text-gold/20 font-mono text-9xl font-bold leading-none mb-8">404</div>
      <div class="ornament mb-6">✦</div>
      <h1 class="font-serif text-3xl text-navy mb-4">Page Not Found</h1>
      <p class="font-sans text-navy/60 leading-relaxed mb-10">
        The folio you seek has not been located in our archives. It may have been moved, removed, or was never copied into this volume. We recommend beginning your search from the index.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-primary">Return Home</a>
        <a href="/formulations" class="btn-outline">View Formulations</a>
      </div>
    </div>
  </div>
</BaseLayout>
