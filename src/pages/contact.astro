---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Contact"
  description="Contact the Historical Translation Project™ for inquiries about formulations, publications, or institutional partnerships."
>
  <Hero
    label="Contact"
    headline="Reach the Institute."
    subheadline="We welcome scholarly inquiries, practitioner partnership questions, publication licensing, and general correspondence regarding the HTP Wellness System."
  />

  <Section>
    <div class="grid md:grid-cols-5 gap-16">
      <!-- Form -->
      <div class="md:col-span-3">
        <form class="space-y-8" action="#" method="POST">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-sans tracking-wider uppercase text-navy/60 mb-2" for="firstName">First Name</label>
              <input
                id="firstName"
                name="firstName"
                type="text"
                required
                class="w-full border border-gold/30 bg-cream-warm px-4 py-3 text-sm font-sans text-navy focus:outline-none focus:border-gold transition-colors"
                placeholder="Your first name"
              />
            </div>
            <div>
              <label class="block text-xs font-sans tracking-wider uppercase text-navy/60 mb-2" for="lastName">Last Name</label>
              <input
                id="lastName"
                name="lastName"
                type="text"
                required
                class="w-full border border-gold/30 bg-cream-warm px-4 py-3 text-sm font-sans text-navy focus:outline-none focus:border-gold transition-colors"
                placeholder="Your last name"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs font-sans tracking-wider uppercase text-navy/60 mb-2" for="email">Email Address</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full border border-gold/30 bg-cream-warm px-4 py-3 text-sm font-sans text-navy focus:outline-none focus:border-gold transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label class="block text-xs font-sans tracking-wider uppercase text-navy/60 mb-2" for="inquiryType">Nature of Inquiry</label>
            <select
              id="inquiryType"
              name="inquiryType"
              class="w-full border border-gold/30 bg-cream-warm px-4 py-3 text-sm font-sans text-navy focus:outline-none focus:border-gold transition-colors"
            >
              <option value="">Select inquiry type</option>
              <option value="formulation">Formulation / Product Access</option>
              <option value="practitioner">Practitioner Partnership</option>
              <option value="publication">Publication / Licensing</option>
              <option value="research">Research Collaboration</option>
              <option value="institutional">Institutional Partnership</option>
              <option value="other">General Inquiry</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-sans tracking-wider uppercase text-navy/60 mb-2" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows={6}
              required
              class="w-full border border-gold/30 bg-cream-warm px-4 py-3 text-sm font-sans text-navy focus:outline-none focus:border-gold transition-colors resize-none"
              placeholder="Describe your inquiry in as much detail as you find helpful..."
            />
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            Submit Inquiry
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </form>
      </div>

      <!-- Info sidebar -->
      <div class="md:col-span-2 space-y-10">
        <div>
          <p class="section-label">Direct Correspondence</p>
          <div class="divider-gold"></div>
          <p class="font-sans text-sm text-navy/65 leading-relaxed mb-3">
            For direct email correspondence:
          </p>
          <a href="mailto:inquiries@historicaltranslationproject.com" class="font-sans text-sm text-gold hover:text-gold-light transition-colors break-all">
            inquiries@historicaltranslationproject.com
          </a>
        </div>

        <div>
          <p class="section-label">Practitioner Access</p>
          <div class="divider-gold"></div>
          <p class="font-sans text-sm text-navy/65 leading-relaxed">
            Qualified healthcare practitioners seeking authorization to prescribe the Advanced module formulation should select "Practitioner Partnership" and include their license number and specialty in their inquiry.
          </p>
        </div>

        <div>
          <p class="section-label">Response Times</p>
          <div class="divider-gold"></div>
          <p class="font-sans text-sm text-navy/65 leading-relaxed">
            We aim to respond to all inquiries within 3–5 business days. Practitioner authorization inquiries may require a longer review period.
          </p>
        </div>

        <div class="bg-navy/5 border border-gold/20 p-6">
          <p class="font-sans text-xs text-navy/50 leading-relaxed">
            We do not provide individual medical advice or respond to inquiries requesting guidance on specific health conditions. All such inquiries should be directed to a qualified healthcare practitioner.
          </p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
