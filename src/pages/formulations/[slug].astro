---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import IngredientTable from '../../components/IngredientTable.astro';
import DosingTable from '../../components/DosingTable.astro';
import DisclaimerBlock from '../../components/DisclaimerBlock.astro';

export async function getStaticPaths() {
  const formulations = await getCollection('formulations');
  return formulations.map(f => ({
    params: { slug: f.data.slug },
    props: { formulation: f.data },
  }));
}

const { formulation: f } = Astro.props;
---

<BaseLayout
  title={f.title}
  description={f.purpose}
>
  <!-- Page header -->
  <div class="bg-navy py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <svg viewBox="0 0 400 300" fill="none" class="absolute right-0 top-0 w-1/2 h-full">
        <circle cx="350" cy="150" r="200" stroke="#b8860b" stroke-width="1"/>
        <circle cx="350" cy="150" r="120" stroke="#b8860b" stroke-width="0.5"/>
      </svg>
    </div>
    <div class="relative max-w-5xl mx-auto px-6 lg:px-12 flex flex-col md:flex-row items-start md:items-center gap-10">
      <div class="w-28 h-28 flex-shrink-0">
        <img src={f.icon} alt={f.title} class="w-full h-full object-contain brightness-0 invert opacity-70" />
      </div>
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-px bg-gold/60"></div>
          <span class={`text-xs tracking-widest uppercase font-sans px-3 py-1
            ${f.type === 'core' ? 'text-cream/80 border border-cream/20' : 'text-gold border border-gold/40'}`}>
            {f.type === 'core' ? 'Core Formulation' : 'Module Formulation'}
          </span>
          {f.practitionerOnly && (
            <span class="text-xs tracking-widest uppercase font-sans text-gold border border-gold px-3 py-1">
              Practitioner Only
            </span>
          )}
        </div>
        <h1 class="font-serif text-3xl md:text-5xl text-cream mb-3">{f.title}</h1>
        <p class="font-sans text-sm text-cream/60 italic">{f.form}</p>
        <p class="font-sans text-base text-cream/70 leading-relaxed mt-4 max-w-xl">{f.tagline}</p>
      </div>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="border-b border-gold/15 bg-cream-warm">
    <div class="max-w-5xl mx-auto px-6 lg:px-12 py-3 flex items-center gap-2 text-xs font-sans text-navy/40">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <span>›</span>
      <a href="/formulations" class="hover:text-gold transition-colors">Formulations</a>
      <span>›</span>
      <span class="text-navy/60">{f.title}</span>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 lg:px-12 py-16 space-y-16">
    <!-- Purpose -->
    <div class="grid md:grid-cols-3 gap-10">
      <div class="md:col-span-2">
        <p class="section-label">Purpose</p>
        <div class="divider-gold"></div>
        <p class="font-sans text-navy/75 leading-relaxed text-base">{f.purpose}</p>
      </div>
      <div>
        <p class="section-label">What This Supports</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.supports.map((s: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <span class="text-gold text-xs mt-1 flex-shrink-0">◆</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Ingredient Table -->
    <div>
      <p class="section-label">Ingredient Specification</p>
      <div class="divider-gold"></div>
      <IngredientTable ingredients={f.ingredients} />
    </div>

    <!-- Dosing -->
    <div>
      <p class="section-label">Suggested Dosing Schedule</p>
      <div class="divider-gold"></div>
      <DosingTable rows={f.dosing} />
      <p class="mt-4 text-xs font-sans text-navy/50 italic">
        Dosing guidance is general. Always follow your practitioner's specific recommendations.
      </p>
    </div>

    <!-- Two column: Safety + Suited For -->
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <p class="section-label">Safety Notes</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.safetyNotes.map((note: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="shrink-0 mt-0.5 text-gold/60">
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1"/>
                <path d="M7 4v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="7" cy="10" r="0.6" fill="currentColor"/>
              </svg>
              {note}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="section-label">Who This May Be Suited For</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.suitedFor.map((s: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <span class="text-gold text-xs mt-1 flex-shrink-0">◆</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- System Role -->
    <div class="bg-navy/5 border-l-4 border-gold p-8">
      <p class="section-label">How It Fits Into the System</p>
      <p class="font-sans text-navy/75 leading-relaxed text-sm">{f.systemRole}</p>
    </div>

    <!-- Purchase CTA -->
    <div class="border border-gold/30 p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <h3 class="font-serif text-xl text-navy mb-1">Request Access</h3>
        <p class="font-sans text-sm text-navy/60">
          {f.practitionerOnly
            ? 'This formulation requires practitioner authorization. Contact us to begin the intake process.'
            : 'This formulation will be available for direct purchase. Join the waitlist to be notified.'}
        </p>
      </div>
      <div class="flex gap-3">
        <a href="/contact" class="btn-primary">
          {f.practitionerOnly ? 'Practitioner Inquiry' : 'Join Waitlist'}
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <DisclaimerBlock practitioner={f.practitionerOnly} />
  </div>
</BaseLayout>
