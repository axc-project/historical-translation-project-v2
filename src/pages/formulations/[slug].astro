---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IngredientTable from '../../components/IngredientTable.astro';
import DosingTable from '../../components/DosingTable.astro';
import DisclaimerBlock from '../../components/DisclaimerBlock.astro';

export async function getStaticPaths() {
  const formulations = await getCollection('formulations');
  return formulations.map(f => ({
    params: { slug: f.data.slug },
    props: { formulation: f.data },
  }));
}

const { formulation: f } = Astro.props;
---

<BaseLayout title={f.title} description={f.purpose}>

  <!-- Page header: dark navy with bottle image -->
  <div class="bg-navy py-20 md:py-28 relative overflow-hidden">
    <!-- Background ornament -->
    <div class="absolute inset-0 opacity-[0.05] pointer-events-none">
      <svg viewBox="0 0 400 300" fill="none" class="absolute right-0 top-0 w-1/2 h-full">
        <circle cx="350" cy="150" r="200" stroke="#b8860b" stroke-width="1"/>
        <circle cx="350" cy="150" r="120" stroke="#b8860b" stroke-width="0.5"/>
      </svg>
    </div>

    <div class="relative max-w-5xl mx-auto px-6 lg:px-12 flex flex-col md:flex-row items-start md:items-center gap-10">

      <!-- Bottle image -->
      <div class="w-40 h-48 md:w-48 md:h-56 flex-shrink-0 flex items-center justify-center">
        {f.bottleImage ? (
          <img
            src={f.bottleImage}
            alt={`${f.title} — Archevia™ dietary supplement bottle`}
            class="w-full h-full object-contain drop-shadow-2xl"
          />
        ) : (
          <img
            src={f.icon}
            alt={f.title}
            class="w-24 h-24 object-contain brightness-0 invert opacity-60"
          />
        )}
      </div>

      <!-- Header text -->
      <div class="flex-1">
        <!-- Badges -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <div class="w-8 h-px bg-gold/60"></div>
          <span class={`text-xs tracking-widest uppercase font-sans px-3 py-1 ${f.type === 'core' ? 'text-cream/80 border border-cream/20' : 'text-gold border border-gold/40'}`}>
            {f.type === 'core' ? 'Core Formulation' : 'Module Formulation'}
          </span>
          {f.practitionerOnly && (
            <span class="text-xs tracking-widest uppercase font-sans text-gold border border-gold px-3 py-1">
              Practitioner Only
            </span>
          )}
        </div>

        <!-- Archevia brand mark -->
        {f.archeviaBrand && (
          <div class="mb-5 flex items-center gap-3">
            <img
              src="/assets/brand/archevia-logo-black.png"
              alt="Archevia™ — formulation brand"
              class="h-16 w-auto"
            />
            <span class="text-xs font-sans text-cream/40 tracking-widest uppercase">Formulation</span>
          </div>
        )}

        <h1 class="font-serif text-3xl md:text-5xl text-cream mb-2">{f.title}</h1>
        <p class="font-sans text-sm text-cream/50 italic mb-1">{f.form}</p>
        <p class="font-sans text-base text-cream/70 leading-relaxed mt-3 max-w-xl">{f.tagline}</p>

        <!-- Dossier: view + download -->
        <div class="mt-6">
          <p class="text-xs font-sans text-cream/40 mb-2 tracking-wide">
            Product Dossier — ingredient monographs, dosing, safety & physician guidance
          </p>
          <div class="flex flex-wrap gap-2">
            <!-- View in browser -->
            <a
              href={`/dossiers/${f.slug}.pdf`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-xs font-sans text-gold border border-gold/50 px-5 py-2.5 hover:bg-gold hover:text-navy transition-all duration-200 font-medium tracking-wide"
            >
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                <rect x="1" y="1" width="11" height="11" rx="1" stroke="currentColor" stroke-width="1.3"/>
                <path d="M4 6.5h5M6.5 4v5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              View Dossier
            </a>
            <!-- Download -->
            <a
              href={`/dossiers/${f.slug}.pdf`}
              download
              class="inline-flex items-center gap-2 text-xs font-sans text-cream/60 border border-cream/20 px-5 py-2.5 hover:border-gold/40 hover:text-gold transition-all duration-200 font-medium tracking-wide"
            >
              <svg width="13" height="14" viewBox="0 0 13 14" fill="none">
                <path d="M6.5 1v8m0 0L3 6m3.5 3L10 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M1 10v2a1 1 0 001 1h9a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              Download PDF
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="border-b border-gold/15 bg-cream-warm">
    <div class="max-w-5xl mx-auto px-6 lg:px-12 py-3 flex items-center gap-2 text-xs font-sans text-navy/40">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <span>›</span>
      <a href="/formulations" class="hover:text-gold transition-colors">Formulations</a>
      <span>›</span>
      <span class="text-navy/60">{f.title}</span>
    </div>
  </div>

  <!-- Body -->
  <div class="max-w-5xl mx-auto px-6 lg:px-12 py-16 space-y-16">

    <!-- Purpose + Supports -->
    <div class="grid md:grid-cols-3 gap-10">
      <div class="md:col-span-2">
        <p class="section-label">Purpose</p>
        <div class="divider-gold"></div>
        <p class="font-sans text-navy/75 leading-relaxed text-base">{f.purpose}</p>
      </div>
      <div>
        <p class="section-label">What This Supports</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.supports.map((s: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <span class="text-gold text-xs mt-1 flex-shrink-0">◆</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Ingredient Table -->
    <div>
      <p class="section-label">Ingredient Specification</p>
      <div class="divider-gold"></div>
      <IngredientTable ingredients={f.ingredients} />
    </div>

    <!-- Dosing Table -->
    <div>
      <p class="section-label">Suggested Dosing Schedule</p>
      <div class="divider-gold"></div>
      <DosingTable rows={f.dosing} />
      <p class="mt-4 text-xs font-sans text-navy/50 italic">
        Dosing guidance is general. Always follow your practitioner's specific recommendations.
      </p>
    </div>

    <!-- Safety + Suited For -->
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <p class="section-label">Safety Notes</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.safetyNotes.map((note: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="shrink-0 mt-0.5 text-gold/60">
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1"/>
                <path d="M7 4v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="7" cy="10" r="0.6" fill="currentColor"/>
              </svg>
              {note}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="section-label">Who This May Be Suited For</p>
        <div class="divider-gold"></div>
        <ul class="space-y-3">
          {f.suitedFor.map((s: string) => (
            <li class="flex items-start gap-2 text-sm font-sans text-navy/70 leading-relaxed">
              <span class="text-gold text-xs mt-1 flex-shrink-0">◆</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- System Role -->
    <div class="bg-navy/5 border-l-4 border-gold p-8">
      <p class="section-label">How It Fits Into the System</p>
      <p class="font-sans text-navy/75 leading-relaxed text-sm">{f.systemRole}</p>
    </div>

    <!-- Access CTA -->
    <div class="border border-gold/30 p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <h3 class="font-serif text-xl text-navy mb-1">Request Access</h3>
        <p class="font-sans text-sm text-navy/60">
          {f.practitionerOnly
            ? 'This formulation requires practitioner authorization. Contact us to begin the intake process.'
            : 'This formulation will be available for direct purchase. Join the waitlist to be notified at launch.'}
        </p>
      </div>
      <div>
        <a href="/contact" class="btn-primary">
          {f.practitionerOnly ? 'Practitioner Inquiry' : 'Join Waitlist'}
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <DisclaimerBlock practitioner={f.practitionerOnly} />
  </div>

</BaseLayout>
