---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import DisclaimerBlock from '../components/DisclaimerBlock.astro';

// Load all ingredient monographs
const allIngredients = await getCollection('ingredients').catch(() => []);

// Group by domain
const domainOrder = ['metabolic','inflammatory','circulatory','cognitive','longevity','cellular','urinary'];
const domainMeta: Record<string, { label: string; title: string; intro: string }> = {
  metabolic: {
    label: '01',
    title: 'Metabolic Terrain',
    intro: 'The metabolic domain encompasses hepatic function, digestive enzyme activity, bile metabolism, and the gut microenvironment. Classical physicians across Arabic, Galenic, and Ayurvedic traditions consistently identified digestive vitality as the foundation of all systemic health — a position that modern metabolic science increasingly validates.',
  },
  inflammatory: {
    label: '02',
    title: 'Inflammatory Balance',
    intro: 'Maintaining the capacity for appropriate acute inflammatory response while avoiding chronic low-grade systemic activation is one of the most active areas of contemporary nutritional research. The Arabic concept of harara (heat dysregulation) and the Galenic concept of calor innatus described this physiological dimension centuries before the cytokine era.',
  },
  circulatory: {
    label: '03',
    title: 'Circulatory Integrity',
    intro: 'Cardiovascular terrain — endothelial function, vascular tone, blood viscosity, and cardiac energetics — was the focus of some of the most sophisticated classical pharmacopoeial traditions. Hawthorn, olive, and grape preparations used for millennia now have mechanistically validated roles in the same physiological terrain.',
  },
  cognitive: {
    label: '04',
    title: 'Cognitive Aging Support',
    intro: "The preservation of cognitive function across the lifespan was a preoccupation of classical physicians from Hippocrates to Ibn Sina to Maimonides. The concept of medhya rasayana (intellect-nourishing medicine) in Ayurveda and the Arabic concept of taqwiyat al-dimagh (brain fortification) anticipated the neuroplasticity and NGF science of the modern era.",
  },
  longevity: {
    label: '05',
    title: 'Longevity & Mitochondrial Resilience',
    intro: "Longevity medicine has identified declining NAD⁺, glutathione depletion, mitochondrial dysfunction, and accumulating cellular senescence as central mechanisms of biological aging. The GlyNAC protocol, sirtuin biology, and NAD⁺ precursor research represent some of the most compelling modern nutritional science — with classical roots in rasayana and rejuvenation traditions.",
  },
  cellular: {
    label: '06',
    title: 'Cellular Resilience',
    intro: 'Supporting the cell\'s intrinsic capacity to manage oxidative stress, maintain genomic integrity, and respond adaptively to environmental challenge is the foundation of preventive nutritional medicine. Nrf2 activation, galectin-3 modulation, and selenoprotein biology represent the molecular substrate of what classical physicians called fortifying the vital spirit.',
  },
  urinary: {
    label: '07',
    title: 'Urinary Comfort & Flow',
    intro: 'Urinary health encompasses bladder mucosal integrity, urinary microenvironment, prostate function, and urothelial anti-adhesion defense. Classical Arabic and Native American botanical traditions identified many of the same plants now validated by modern anti-adhesion and phytosterol research.',
  },
};

const grouped: Record<string, typeof allIngredients> = {};
for (const domain of domainOrder) {
  grouped[domain] = allIngredients.filter(i => i.data.domain === domain);
}

// All formulas for lookup
const allFormulas = await getCollection('formulations').catch(() => []);
const formulaMap: Record<string, string> = {};
for (const f of allFormulas) {
  formulaMap[f.data.slug] = f.data.title;
}

const totalIngredients = allIngredients.length;
const totalFormulas = allFormulas.length;
---

<BaseLayout
  title="Research & Ingredient Monographs"
  description="Comprehensive ingredient monograph library from Historical Translation Project™ — historical use, modern evidence, mechanisms, safety profiles, and clinical guidance for every active ingredient."
>
  <Hero
    label="Research Library"
    headline={"Evidence.\nHistory.\nTransparency."}
    subheadline="A complete monograph for every ingredient we use — historical roots, modern mechanisms, clinical safety, and physician guidance. This library grows with every formulation we develop."
  />

  <!-- Stats bar -->
  <div class="bg-navy border-b border-gold/20">
    <div class="max-w-5xl mx-auto px-6 lg:px-12 py-5 grid grid-cols-3 md:grid-cols-4 gap-6">
      {[
        { n: String(totalIngredients), label: 'Active Ingredients' },
        { n: String(totalFormulas), label: 'Formulations' },
        { n: '7', label: 'Physiological Domains' },
        { n: '2', label: 'Published Volumes' },
      ].map(stat => (
        <div class="text-center">
          <p class="font-serif text-2xl text-gold">{stat.n}</p>
          <p class="font-sans text-xs text-cream/50 tracking-widest uppercase mt-1">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Domain navigation tabs -->
  <div class="sticky top-0 z-30 bg-cream-warm border-b border-gold/20 shadow-sm">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">
      <div class="flex overflow-x-auto gap-0 hide-scrollbar">
        {domainOrder.map(domain => {
          const meta = domainMeta[domain];
          const count = grouped[domain]?.length ?? 0;
          if (count === 0) return null;
          return (
            <a href={`#domain-${domain}`}
               class="flex-shrink-0 flex items-center gap-2 px-5 py-4 text-xs font-sans font-medium tracking-widest uppercase text-navy/50 hover:text-gold border-b-2 border-transparent hover:border-gold transition-all whitespace-nowrap">
              <span class="text-gold/50 font-serif">{meta.label}</span>
              {meta.title}
              <span class="text-gold/60 font-mono text-[10px] bg-navy/8 px-1.5 py-0.5">{count}</span>
            </a>
          );
        })}
        <a href="/publications"
           class="flex-shrink-0 flex items-center gap-2 px-5 py-4 text-xs font-sans font-medium tracking-widest uppercase text-gold/70 hover:text-gold border-b-2 border-transparent hover:border-gold transition-all whitespace-nowrap ml-auto">
          Publications ›
        </a>
      </div>
    </div>
  </div>

  <!-- Monograph library -->
  <div class="max-w-5xl mx-auto px-6 lg:px-12 py-16 space-y-24">

    {domainOrder.map(domain => {
      const meta = domainMeta[domain];
      const ingredients = grouped[domain] ?? [];
      if (ingredients.length === 0) return null;
      return (
        <section id={`domain-${domain}`} class="scroll-mt-20">

          <!-- Domain header -->
          <div class="flex items-start gap-6 mb-10">
            <div class="hidden md:block">
              <span class="font-serif text-5xl text-gold/20 font-bold leading-none">{meta.label}</span>
            </div>
            <div class="flex-1">
              <p class="section-label">{meta.title}</p>
              <div class="divider-gold"></div>
              <p class="font-sans text-sm text-navy/65 leading-relaxed max-w-3xl">{meta.intro}</p>
            </div>
          </div>

          <!-- Ingredient accordion cards -->
          <div class="space-y-3">
            {ingredients.map((ing, idx) => {
              const i = ing.data;
              const formulaTitles = (i.formulas || []).map((s: string) => formulaMap[s] || s);
              return (
                <details class="group border border-gold/20 hover:border-gold/40 transition-all duration-200 bg-cream-warm">
                  <!-- Summary row (always visible) -->
                  <summary class="flex items-center gap-4 px-6 py-5 cursor-pointer list-none select-none">
                    <!-- Expand icon -->
                    <span class="flex-shrink-0 w-6 h-6 border border-gold/40 flex items-center justify-center text-gold group-open:rotate-45 transition-transform duration-200">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </span>

                    <!-- Name + latin name -->
                    <div class="flex-1 min-w-0">
                      <h3 class="font-serif text-base text-navy group-hover:text-gold/80 transition-colors leading-tight">
                        {i.name}
                      </h3>
                      <p class="font-sans text-xs text-navy/40 italic mt-0.5">{i.latinName}</p>
                    </div>

                    <!-- Standardization pill -->
                    <span class="hidden md:block text-xs font-sans text-navy/50 border border-navy/15 px-3 py-1 whitespace-nowrap flex-shrink-0">
                      {i.standardization}
                    </span>

                    <!-- Domain badge -->
                    <span class="hidden lg:block text-xs font-sans tracking-widest uppercase text-gold/70 flex-shrink-0">
                      {i.domainLabel}
                    </span>

                    <!-- Formula pills -->
                    <div class="hidden md:flex gap-1.5 flex-shrink-0 flex-wrap justify-end max-w-48">
                      {formulaTitles.slice(0,2).map((ft: string) => (
                        <span class="text-[10px] font-sans text-navy/50 bg-navy/6 border border-navy/10 px-2 py-0.5 leading-tight whitespace-nowrap">
                          {ft.replace('™','').split('(')[0].trim()}
                        </span>
                      ))}
                      {formulaTitles.length > 2 && (
                        <span class="text-[10px] font-sans text-navy/40 px-2 py-0.5">
                          +{formulaTitles.length - 2}
                        </span>
                      )}
                    </div>
                  </summary>

                  <!-- Expanded content -->
                  <div class="border-t border-gold/15 px-6 pb-8 pt-6">
                    <div class="grid md:grid-cols-2 gap-8">

                      <!-- Left column -->
                      <div class="space-y-6">

                        <!-- Historical Use -->
                        <div>
                          <p class="text-xs font-sans font-medium tracking-widest uppercase text-gold mb-2">Historical Use</p>
                          <p class="font-sans text-sm text-navy/70 leading-relaxed">{i.historicalUse}</p>
                          {i.classicalSources && i.classicalSources.length > 0 && (
                            <div class="mt-3 pl-3 border-l border-gold/30">
                              <p class="text-xs font-sans text-navy/40 italic font-medium mb-1">Classical Sources</p>
                              {i.classicalSources.map((src: string) => (
                                <p class="text-xs font-sans text-navy/50 italic leading-relaxed">{src}</p>
                              ))}
                            </div>
                          )}
                        </div>

                        <!-- Modern Evidence -->
                        <div>
                          <p class="text-xs font-sans font-medium tracking-widest uppercase text-gold mb-2">Modern Evidence</p>
                          <p class="font-sans text-sm text-navy/70 leading-relaxed">{i.modernEvidence}</p>
                        </div>

                        <!-- Mechanisms -->
                        <div>
                          <p class="text-xs font-sans font-medium tracking-widest uppercase text-gold mb-2">Mechanisms of Action</p>
                          <ul class="space-y-1.5">
                            {(i.mechanisms || []).map((m: string) => (
                              <li class="flex items-start gap-2 text-sm font-sans text-navy/65 leading-relaxed">
                                <span class="text-gold/50 mt-0.5 flex-shrink-0 text-xs">→</span>
                                {m}
                              </li>
                            ))}
                          </ul>
                        </div>

                        <!-- Benefits -->
                        <div>
                          <p class="text-xs font-sans font-medium tracking-widest uppercase text-gold mb-2">Key Benefits</p>
                          <ul class="space-y-1.5">
                            {(i.benefits || []).map((b: string) => (
                              <li class="flex items-start gap-2 text-sm font-sans text-navy/65 leading-relaxed">
                                <span class="text-gold flex-shrink-0 text-xs mt-0.5">◆</span>
                                {b}
                              </li>
                            ))}
                          </ul>
                        </div>

                      </div>

                      <!-- Right column -->
                      <div class="space-y-6">

                        <!-- Safety -->
                        <div class="bg-amber-50/60 border border-amber-200/60 p-5">
                          <p class="text-xs font-sans font-medium tracking-widest uppercase text-amber-700 mb-2">Safety Profile</p>
                          <p class="font-sans text-sm text-navy/70 leading-relaxed mb-4">{i.safetyProfile}</p>

                          {i.contraindications && i.contraindications.length > 0 && (
                            <div>
                              <p class="text-xs font-sans font-medium tracking-widest uppercase text-red-700/80 mb-2 mt-3">Contraindications</p>
                              <ul class="space-y-1.5">
                                {i.contraindications.map((c: string) => (
                                  <li class="flex items-start gap-2 text-sm font-sans text-red-800/70 leading-relaxed">
                                    <span class="flex-shrink-0 mt-0.5">⚠</span>
                                    {c}
                                  </li>
                                ))}
                              </ul>
                            </div>
                          )}
                        </div>

                        <!-- Drug Interactions -->
                        {i.drugInteractions && i.drugInteractions.length > 0 && (
                          <div class="bg-red-50/50 border border-red-200/60 p-5">
                            <p class="text-xs font-sans font-medium tracking-widest uppercase text-red-700/80 mb-3">Drug Interactions</p>
                            <ul class="space-y-2">
                              {i.drugInteractions.map((di: string) => {
                                const isCritical = di.toUpperCase().startsWith('CRITICAL');
                                return (
                                  <li class={`flex items-start gap-2 text-sm font-sans leading-relaxed ${isCritical ? 'text-red-800 font-medium' : 'text-navy/65'}`}>
                                    <span class={`flex-shrink-0 mt-0.5 ${isCritical ? 'text-red-700' : 'text-navy/30'}`}>
                                      {isCritical ? '⚠' : '·'}
                                    </span>
                                    {di}
                                  </li>
                                );
                              })}
                            </ul>
                          </div>
                        )}

                        <!-- Physician Notes -->
                        {i.physicianNotes && (
                          <div class="bg-navy/5 border-l-4 border-navy/30 p-5">
                            <p class="text-xs font-sans font-medium tracking-widest uppercase text-navy/50 mb-2">Clinical / Physician Notes</p>
                            <p class="font-sans text-sm text-navy/70 leading-relaxed">{i.physicianNotes}</p>
                          </div>
                        )}

                        <!-- Patient Guidance -->
                        {i.patientGuidance && (
                          <div class="bg-gold/5 border-l-4 border-gold/40 p-5">
                            <p class="text-xs font-sans font-medium tracking-widest uppercase text-gold/80 mb-2">Patient Guidance</p>
                            <p class="font-sans text-sm text-navy/70 italic leading-relaxed">{i.patientGuidance}</p>
                          </div>
                        )}

                        <!-- Formulas that use this ingredient -->
                        {formulaTitles.length > 0 && (
                          <div>
                            <p class="text-xs font-sans font-medium tracking-widest uppercase text-navy/40 mb-2">Found In</p>
                            <div class="flex flex-wrap gap-2">
                              {(i.formulas || []).map((slug: string) => (
                                <a href={`/formulations/${slug}`}
                                   class="text-xs font-sans text-gold/80 border border-gold/30 px-3 py-1 hover:bg-gold/10 transition-colors">
                                  {(formulaMap[slug] || slug).replace('™','').split('(')[0].trim()} ›
                                </a>
                              ))}
                            </div>
                          </div>
                        )}

                        <!-- Linked publications -->
                        {i.linkedPublications && i.linkedPublications.length > 0 && (
                          <div>
                            <p class="text-xs font-sans font-medium tracking-widest uppercase text-navy/40 mb-2">Related Publications</p>
                            <a href="/publications" class="inline-flex items-center gap-1.5 text-xs font-sans text-gold/70 hover:text-gold transition-colors">
                              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <rect x="1" y="1" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1"/>
                                <path d="M3 4h6M3 6h6M3 8h4" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                              </svg>
                              View in Publications Library
                            </a>
                          </div>
                        )}

                      </div>
                    </div>
                  </div>
                </details>
              );
            })}
          </div>

        </section>
      );
    })}

  </div>

  <!-- CTA strip -->
  <div class="bg-navy border-y border-gold/20 py-14">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="section-label text-cream/50">Growing Library</p>
      <div class="divider-gold mx-auto"></div>
      <h3 class="font-serif text-2xl text-cream mb-4">
        This database grows with every formulation.
      </h3>
      <p class="font-sans text-sm text-cream/60 leading-relaxed mb-8 max-w-xl mx-auto">
        Each new ingredient we introduce receives a full monograph before it enters any formula.
        This library is the foundation of our AI research agent and the source data for every product dossier.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/formulations" class="btn-primary">Explore Formulations</a>
        <a href="/publications" class="inline-flex items-center gap-2 text-sm font-sans text-cream/60 hover:text-gold transition-colors border-b border-cream/20 hover:border-gold pb-0.5">
          View Publications ›
        </a>
      </div>
    </div>
  </div>

  <Section tight>
    <DisclaimerBlock />
  </Section>

</BaseLayout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  details > summary::-webkit-details-marker { display: none; }
</style>
