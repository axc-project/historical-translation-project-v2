---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Legal Disclaimers"
  description="Legal disclaimers, DSHEA notices, and terms of use for the Historical Translation Project™."
  noindex={true}
>
  <div class="bg-navy py-16">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label text-gold">Legal & Compliance</p>
      <h1 class="font-serif text-3xl md:text-4xl text-cream">Disclaimers & Legal Notices</h1>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-16 space-y-16">
    <!-- DSHEA -->
    <div id="dshea">
      <p class="section-label">DSHEA Notice</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p class="font-sans text-sm text-navy/80 leading-relaxed font-medium border-l-4 border-gold/50 pl-6 py-3 bg-gold/5">
          These statements have not been evaluated by the Food and Drug Administration. These products are not intended to diagnose, treat, cure, or prevent any disease.
        </p>
        <p>
          All formulations offered by the Historical Translation Project™ are dietary supplements regulated under the Dietary Supplement Health and Education Act of 1994 (DSHEA). Structure/function claims made on this website describe how nutrients or dietary ingredients are intended to affect the normal structure or function of the human body. These claims do not imply disease treatment or prevention of any kind.
        </p>
        <p>
          The FDA has not approved these products for any therapeutic purpose. No claims on this website should be interpreted as implying clinical efficacy for any diagnosed medical condition.
        </p>
      </div>
    </div>

    <!-- Educational Content -->
    <div id="educational">
      <p class="section-label">Educational Content Disclaimer</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p>
          All content on this website — including descriptions of physiological domains, ingredient profiles, historical botanical information, and research summaries — is provided for educational and informational purposes only. It is not intended to constitute medical advice, clinical guidance, or therapeutic recommendations.
        </p>
        <p>
          Historical information about classical botanical medicine is provided for scholarly and contextual purposes. References to historical use do not constitute claims of clinical efficacy for modern applications of the same compounds or preparations.
        </p>
        <p>
          Research summaries and "Selected Reading" categories are provided to help readers orient themselves within the relevant scientific literature. They are not comprehensive systematic reviews and should not be relied upon as the sole basis for health decisions.
        </p>
      </div>
    </div>

    <!-- Not Medical Advice -->
    <div>
      <p class="section-label">Not Medical Advice</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p>
          The Historical Translation Project™ is not a medical institution and does not provide medical advice. No content on this website, and no communication from our team, constitutes a doctor-patient or clinician-patient relationship. We do not diagnose medical conditions, we do not prescribe treatments, and we do not advise on the management of any specific health condition.
        </p>
        <p>
          If you have a diagnosed medical condition, are taking prescription medications, are pregnant or nursing, or have concerns about your health, you should consult a qualified, licensed healthcare practitioner before using any dietary supplement, including products from the HTP system.
        </p>
        <p>
          Nothing on this website should be used as a substitute for professional medical advice, diagnosis, or treatment. Always seek the advice of your physician or other qualified health provider with any questions you may have regarding a medical condition.
        </p>
      </div>
    </div>

    <!-- Practitioner-Only -->
    <div>
      <p class="section-label">Practitioner-Only Formulations</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p>
          The Cellular Resilience Advanced (Practitioner Guided)™ formulation is designed for use only under the direct supervision of a qualified, licensed healthcare practitioner. It is not available for general retail purchase or self-directed use.
        </p>
        <p>
          Practitioners seeking authorization to recommend or prescribe this formulation to their patients must complete our practitioner intake process. By using or recommending this formulation, authorized practitioners assume responsibility for appropriate clinical oversight, monitoring, and patient communication regarding its use.
        </p>
        <p>
          The Historical Translation Project™ makes no representations as to the clinical outcomes of this or any other formulation. Practitioners bear independent responsibility for the advice and guidance they provide to their patients.
        </p>
      </div>
    </div>

    <!-- Privacy -->
    <div id="privacy">
      <p class="section-label">Privacy Notice</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p>
          We collect only the personal information that you voluntarily provide through our contact form, including name, email address, and the content of your inquiry. This information is used solely to respond to your inquiry and is not shared with third parties for marketing purposes.
        </p>
        <p>
          We do not sell personal data. We use standard industry security practices to protect the information you provide. By submitting our contact form, you consent to the use of your information for the purpose of responding to your inquiry.
        </p>
      </div>
    </div>

    <!-- Terms -->
    <div id="terms">
      <p class="section-label">Terms of Use</p>
      <div class="divider-gold"></div>
      <div class="prose-htp">
        <p>
          By accessing and using this website, you agree to these terms of use. All content on this website is the intellectual property of the Historical Translation Project™ and may not be reproduced, distributed, or repurposed without written permission.
        </p>
        <p>
          You agree not to use this website for any unlawful purpose, not to attempt to access systems or data not intended for your use, and not to misrepresent the content of this website in any public or commercial communication.
        </p>
        <p>
          We reserve the right to modify these terms at any time. Continued use of the website following any modification constitutes acceptance of the updated terms.
        </p>
      </div>
    </div>

    <div class="border-t border-gold/20 pt-8">
      <p class="font-sans text-xs text-navy/40 italic">
        Last reviewed: 2024. Historical Translation Project™ is a registered trademark. All rights reserved.
      </p>
    </div>
  </div>
</BaseLayout>
